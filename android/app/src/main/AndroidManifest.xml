<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_widget"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MeteoDuoWidget">

        <!-- Appka (WebView s webovým MeteoDuo) — ikona v zásuvke aj cieľ ťuknutia na widget -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Widget provider: Android ho podľa updatePeriodMillis sám obnovuje -->
        <receiver
            android:name=".WeatherWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/weather_widget_info" />
        </receiver>

        <!-- Konfigurácia pri pridaní widgetu: výber mesta (SHMÚ id) -->
        <activity
            android:name=".WidgetConfigActivity"
            android:exported="true"
            android:label="@string/config_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>
    </application>
</manifest>
