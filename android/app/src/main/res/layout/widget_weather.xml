<?xml version="1.0" encoding="utf-8"?>
<!-- Pozadie je samostatný ImageView, aby sa naň dala cez RemoteViews
     nastaviť priehľadnosť (setImageAlpha) nezávisle od textu. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null"
        android:src="@drawable/widget_background" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp">

        <TextView
            android:id="@+id/w_city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/w_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="Bratislava (centrum)" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/w_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="30sp"
                android:layout_marginEnd="8dp"
                android:text="⛅" />

            <TextView
                android:id="@+id/w_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/w_text"
                android:textSize="40sp"
                android:textStyle="bold"
                android:text="–" />
        </LinearLayout>

        <TextView
            android:id="@+id/w_condition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/w_text"
            android:textSize="14sp"
            android:text="—" />

        <TextView
            android:id="@+id/w_hilo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/w_muted"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:text="" />

        <TextView
            android:id="@+id/w_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/w_muted"
            android:textSize="10sp"
            android:layout_marginTop="4dp"
            android:text="" />
    </LinearLayout>

    <!-- ⚙ otvorí nastavenia (mesto / obľúbené / priehľadnosť) hocikedy -->
    <TextView
        android:id="@+id/w_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:padding="6dp"
        android:textSize="14sp"
        android:text="⚙"
        android:contentDescription="@string/settings_desc" />
</FrameLayout>
