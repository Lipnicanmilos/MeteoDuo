<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/config_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/config_search_label"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <AutoCompleteTextView
            android:id="@+id/cfg_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/config_search_hint"
            android:completionThreshold="1"
            android:inputType="text"
            android:importantForAutofill="no" />

        <TextView
            android:id="@+id/cfg_selected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textStyle="bold"
            android:text="" />

        <Button
            android:id="@+id/cfg_addfav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/config_add_fav" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/config_favs_label"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/cfg_favs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/cfg_favs_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/config_favs_empty"
            android:textColor="#888888"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/cfg_alpha_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/config_alpha_label"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/cfg_alpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100" />

        <Button
            android:id="@+id/cfg_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/config_save" />
    </LinearLayout>
</ScrollView>
